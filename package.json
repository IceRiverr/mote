{
  "name": "mote",
  "version": "1.0.0",
  "description": "mote — 轻量级 WebGPU 2D 游戏引擎",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "games/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "bundle": "node scripts/bundle-html.mjs",
    "deploy": "npm run build && node scripts/deploy.mjs",
    "deploy:full": "npm run build && scp -r dist/* root@8.210.175.90:/var/www/iceriver.cc/",
    "commit": "bash git-commit.sh",
    "cz": "bash git-commit.sh",
    "test": "npm run test --workspace=@mote/map-editor",
    "test:watch": "npm run test:watch --workspace=@mote/map-editor",
    "test:coverage": "npm run test:coverage --workspace=@mote/map-editor",
    "test:all": "npm test --workspaces"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@webgpu/types": "^0.1.69",
    "ssh2-sftp-client": "^9.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vite-plugin-static-copy": "^4.0.0"
  }
}
