{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@mote/engine": ["../engine/src/index.ts"],
      "@mote/engine/*": ["../engine/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
