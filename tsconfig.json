{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "esModuleInterop": true,
    "sourceMap": true,
    "lib": ["ESNext", "DOM"],
    "types": ["@webgpu/types"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@mote/engine":   ["./packages/engine/src/index.ts"],
      "@mote/engine/*": ["./packages/engine/src/*"]
    }
  },
  "include": ["packages", "games"],
  "exclude": ["vite.config.ts", "**/dist/**", "**/assets/**", "packages/engine/src/TileMapRenderer.ts", "packages/engine/scripts/extract-schemas.ts"]
}
