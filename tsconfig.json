{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "./dist",
    "lib": ["ESNext", "DOM"],
    "types": ["@webgpu/types"],
    "skipLibCheck": true
  },
  "include": ["src", "games"],
  "exclude": ["vite.config.ts"]
}